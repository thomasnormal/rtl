        "golden_rtl_dir": "golden_rtl",
        "overlay_rel_dir": "hw/ip/uart/rtl",
        "mutants": [
          {
            "name": "tx_enable_tied_low",
            "edits": [
              {
                "path": "uart.sv",
                "find": "  assign cio_tx_en_o = 1'b1;\n",
                "replace": "  assign cio_tx_en_o = 1'b0;\n"
              }
            ]
          },
          {
            "name": "tx_done_interrupt_disabled",
            "edits": [
              {
                "path": "uart_core.sv",
                "find": "  assign event_tx_done = ~tx_fifo_rvalid & ~tx_uart_idle_q & tx_uart_idle;\n",
                "replace": "  assign event_tx_done = 1'b0;\n"
              }
            ]
          },
          {
            "name": "rx_data_zeroed",
            "edits": [
              {
                "path": "uart_core.sv",
                "find": "  assign hw2reg.rdata.d = uart_rdata;\n",
                "replace": "  assign hw2reg.rdata.d = '0;\n"
              }
            ]
          }
        ],
        "assets": [
          {
            "source": "hw/ip/uart/rtl",
            "dest": "golden_rtl"
          },
          {
            "source_base": "task_library_root",
            "source": "_hidden/uart/repo_overlay/hw/ip/uart/dv/tb/tb.sv",
            "dest": "repo_overlay/hw/ip/uart/dv/tb/tb.sv"
